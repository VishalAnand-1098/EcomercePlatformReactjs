# ─── Frontend (Vite — bundled into browser) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
VITE_SITE_URL=https://your-app.vercel.app

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# Set these with the Supabase CLI (NOT in .env — they live in Supabase Vault):
#   supabase secrets set RESEND_API_KEY=re_your_key
#   supabase secrets set SITE_URL=https://your-app.vercel.app
#   supabase secrets set RESEND_FROM_EMAIL=GiftsBhejo <onboarding@resend.dev>
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically.

# ─── Optional ─────────────────────────────────────────────────────────────────
# VITE_RAZORPAY_KEY_ID=
